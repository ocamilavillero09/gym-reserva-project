# Paso 1: Usar una imagen de Node.js ligera para construir la app
FROM node:18-alpine

# Establecer el directorio de trabajo dentro del contenedor
WORKDIR /app

# Copiar los archivos de dependencias primero (esto optimiza la caché de Docker)
COPY package.json ./

# Instalar las dependencias del proyecto
RUN npm install

# Copiar todo el código fuente del frontend al contenedor
COPY . .

# Exponer el puerto por donde correrá la aplicación (generalmente 3000 para React)
EXPOSE 3000

# Comando para iniciar la aplicación en modo desarrollo
CMD ["npm", "start"]